PORT=5000
NODE_ENV=development
CORS_ORIGIN=*

# --- Firebase / Firestore ---
# Option A (recommended for local dev): path to the service account
# JSON key you downloaded from Firebase Console. Relative paths are
# resolved from the backend/ folder.
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Option B (recommended for hosting providers where uploading a file
# is awkward, e.g. Render/Railway/Vercel): paste the ENTIRE contents
# of the JSON key file as a single-line env var instead. If this is
# set, it takes priority over FIREBASE_SERVICE_ACCOUNT_PATH.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...", ...}
